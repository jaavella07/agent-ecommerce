# OpenAI (desactivado — actualmente se usa Ollama como proveedor de inferencia)
# Descomentar y completar si se desea volver a usar OpenAI (ver src/super_agent/shared/llm.ts)
# OPENAI_API_KEY=

# LangChain / LangSmith (trazado y observabilidad — opcional)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agent-ecommerce

# Ollama — servidor local o remoto (Open WebUI / hosting)
# El modelo debe soportar tool-calling: qwen2.5:7b, llama3.1, mistral-nemo, etc.
# Para servidor local: OLLAMA_BASE_URL=http://localhost:11434
# Para servidor remoto (Open WebUI): OLLAMA_BASE_URL=https://<tu-host>/ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Auth del hosting (dejar en blanco si no aplica)
OLLAMA_X_API_KEY=
OLLAMA_MY_KEY=

# PostgreSQL local (Docker Compose)
DATABASE_URL=postgresql://agent_user:agent_pass@localhost:5432/ecommerce_agent

# NestJS API base URL (debe incluir /api/v1)
API_BASE_URL=http://localhost:3000/api/v1

# Credenciales de admin para el API de TechsStore
API_ADMIN_EMAIL=
API_ADMIN_PASSWORD=